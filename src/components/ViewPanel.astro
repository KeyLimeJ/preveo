---
---
<aside class="artifact-panel">
  <div class="artifact-header">
    <button class="artifact-btn" id="views-menu-btn" title="Views">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="artifact-panel-title" id="view-panel-title"></div>
    <div class="artifact-actions">
      <button class="artifact-btn"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></button>
      <button class="artifact-btn"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>
    </div>
  </div>

  <div class="artifact-content-wrap">
    <div class="artifact-body">
      <div class="artifact-empty">
        <svg width="32" height="23" viewBox="0 0 48 34" fill="none">
          <circle cx="24" cy="24" r="13" fill="#0E1420" opacity="0.12"/>
          <rect x="0" y="24" width="48" height="12" fill="var(--s1)"/>
          <line x1="0" y1="24" x2="48" y2="24" stroke="var(--rule)" stroke-width="1"/>
        </svg>
        <div class="artifact-empty-label" id="view-empty-label"></div>
        <div class="artifact-empty-sub" id="view-empty-sub">View will appear here</div>
      </div>
    </div>

    <div class="services-overlay" id="views-overlay">
      <div class="services-overlay-header">
        <div class="services-overlay-title">Views</div>
        <button class="services-overlay-close" id="views-overlay-close">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="services-overlay-body">
        <div class="sov-group">
          <div class="sov-label">Views</div>
          <div class="sov-items">
            <button class="sov-item active" data-service="view-01">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              Contact Info
            </button>
            <button class="sov-item" data-service="view-02">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              View 02
            </button>
            <button class="sov-item" data-service="view-03">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              View 03
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</aside>

<div class="artifact-bottom"></div>
