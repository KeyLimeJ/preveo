---
// src/pages/index.astro
// Landing page — migrated from preveo_landing.html
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Preveo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600&family=DM+Mono:wght@300;400&family=Instrument+Serif:ital@1&display=swap" rel="stylesheet">
<style is:global>
:root {
  --s0:#F6F8FC; --s1:#FFFFFF; --s2:#F0F3FA;
  --slate:#1E2D4A; --slate-deep:#141E33; --slate-mid:#2A3D62;
  --slate-pale:#EBF0FA; --slate-rule:#C8D2E8; --slate-mist:#F2F5FB;
  --amber:#C87820; --amber-light:#E8960A; --amber-bg:#FDF5EA; --amber-rule:#EDD390;
  --t0:#0E1420; --t1:#3A4560; --t2:#7080A0; --t3:#B8C4D4;
  --rule:#E4EAF4; --rule-soft:#EDF1F9;
  --green:#16A34A; --signal:#B84020;
}

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  font-family:'Outfit',sans-serif;
  font-weight:300;
  background:var(--slate-deep);
  color:var(--t0);
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}

/* ── NAV ─────────────────────────────────────────────────── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  height:52px;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 48px;
  background:rgba(20,30,51,0.80);
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(255,255,255,0.06);
}
.nav-logo{display:flex;align-items:center;gap:11px;text-decoration:none}
.nav-wordmark{
  font-size:20px;font-weight:600;letter-spacing:-0.03em;
  color:#F4F6FA;line-height:1;
}
/* "veo" rendered by JS with Instrument Serif italic in --slate-rule */
.nav-wordmark .veo{
  font-family:'Instrument Serif',serif;
  font-style:italic;font-weight:400;
  color:var(--slate-rule);letter-spacing:0;
}
.nav-links{display:flex;align-items:center;gap:4px}
.nav-link{
  padding:6px 13px;border-radius:5px;
  font-size:13px;font-weight:300;
  color:rgba(255,255,255,0.45);
  text-decoration:none;transition:all 0.12s;
}
.nav-link:hover{color:rgba(255,255,255,0.82);background:rgba(255,255,255,0.05)}
.nav-right{display:flex;align-items:center;gap:10px}
.nav-signin{
  padding:7px 16px;border-radius:5px;
  border:1px solid rgba(255,255,255,0.10);
  background:transparent;
  font-family:'Outfit';font-size:13px;font-weight:300;
  color:rgba(255,255,255,0.50);
  cursor:pointer;transition:all 0.12s;text-decoration:none;
}
.nav-signin:hover{color:rgba(255,255,255,0.85);border-color:rgba(255,255,255,0.22)}
.nav-cta{
  padding:7px 18px;border-radius:5px;
  background:var(--amber);border:none;
  font-family:'Outfit';font-size:13px;font-weight:500;
  color:#fff;cursor:pointer;transition:all 0.15s;text-decoration:none;
  letter-spacing:0.01em;
}
.nav-cta:hover{background:var(--amber-light)}

/* ── HERO ─────────────────────────────────────────────────── */
.hero{
  min-height:100vh;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:120px 48px 80px;
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(200,120,32,0.022) 1px,transparent 1px),
    linear-gradient(90deg,rgba(200,120,32,0.022) 1px,transparent 1px);
  background-size:60px 60px;
  pointer-events:none;
}
.glow-amber{
  position:absolute;bottom:-160px;right:-100px;
  width:800px;height:800px;
  background:radial-gradient(circle,rgba(200,120,32,0.11) 0%,transparent 60%);
  pointer-events:none;
}
.glow-slate{
  position:absolute;top:-80px;left:-120px;
  width:700px;height:700px;
  background:radial-gradient(circle,rgba(42,61,98,0.45) 0%,transparent 65%);
  pointer-events:none;
}
.hero-horizon{
  position:absolute;bottom:18%;left:0;right:0;height:1px;
  background:linear-gradient(to right,transparent 5%,rgba(200,120,32,0.22) 30%,rgba(200,120,32,0.22) 70%,transparent 95%);
}
/* Rising sun mark above horizon line */
.hero-sun{
  position:absolute;bottom:18%;left:50%;
  transform:translateX(-50%) translateY(50%);
  width:28px;height:28px;
  overflow:hidden;
}
.hero-sun svg{position:absolute;bottom:0;left:50%;transform:translateX(-50%)}

.hero-inner{
  position:relative;z-index:1;
  display:flex;flex-direction:column;align-items:center;
  text-align:center;max-width:760px;width:100%;
}
.hero-eyebrow{
  font-family:'DM Mono',monospace;
  font-size:9px;letter-spacing:0.32em;text-transform:uppercase;
  color:var(--amber);opacity:0.7;
  margin-bottom:28px;
  display:flex;align-items:center;gap:14px;
  animation:fadeUp 0.7s ease 0.1s both;
}
.hero-eyebrow::before,.hero-eyebrow::after{
  content:'';display:block;width:24px;height:1px;
  background:var(--amber);opacity:0.5;
}
.hero-headline{
  font-size:clamp(46px,5.5vw,76px);
  font-weight:600;letter-spacing:-0.04em;
  color:#F4F6FA;line-height:1.05;
  margin-bottom:24px;
  animation:fadeUp 0.8s ease 0.2s both;
}
.hero-sub{
  font-size:16px;font-weight:300;
  color:rgba(244,246,250,0.45);line-height:1.75;
  max-width:480px;margin-bottom:44px;
  animation:fadeUp 0.8s ease 0.3s both;
}
.hero-actions{
  display:flex;align-items:center;gap:12px;
  margin-bottom:64px;
  animation:fadeUp 0.8s ease 0.4s both;
}
.btn-primary{
  padding:13px 28px;border-radius:7px;border:none;
  background:var(--amber);color:#fff;
  font-family:'Outfit';font-size:14px;font-weight:500;
  cursor:pointer;transition:all 0.15s;text-decoration:none;
  letter-spacing:0.01em;display:inline-flex;align-items:center;
}
.btn-primary:hover{background:var(--amber-light);transform:translateY(-1px)}
.btn-ghost{
  padding:13px 24px;border-radius:7px;
  border:1px solid rgba(255,255,255,0.12);
  background:transparent;color:rgba(255,255,255,0.6);
  font-family:'Outfit';font-size:14px;font-weight:300;
  cursor:pointer;transition:all 0.15s;text-decoration:none;
  display:inline-flex;align-items:center;gap:8px;
}
.btn-ghost:hover{border-color:rgba(255,255,255,0.25);color:rgba(255,255,255,0.88)}
.btn-ghost svg{opacity:0.6}
.hero-proof{
  display:flex;align-items:center;gap:16px;
  animation:fadeUp 0.8s ease 0.5s both;
}
.proof-avatars{display:flex}
.proof-avatar{
  width:26px;height:26px;border-radius:50%;
  background:var(--slate-mid);border:2px solid var(--slate-deep);
  margin-left:-8px;display:flex;align-items:center;justify-content:center;
  font-size:9px;font-weight:500;color:rgba(255,255,255,0.7);
}
.proof-avatar:first-child{margin-left:0}
.proof-text{font-size:12px;font-weight:300;color:rgba(255,255,255,0.35)}

/* ── APP PREVIEW ─────────────────────────────────────────── */
.preview-wrap{
  width:100%;max-width:960px;margin:0 auto;
  padding:0 48px 100px;
  position:relative;z-index:1;
  animation:fadeUp 0.9s ease 0.55s both;
}
.preview-frame{
  background:var(--s1);
  border-radius:12px;
  border:1px solid rgba(255,255,255,0.08);
  box-shadow:
    0 0 0 1px rgba(200,120,32,0.07),
    0 40px 80px rgba(0,0,0,0.48),
    0 0 60px rgba(200,120,32,0.05);
  overflow:hidden;
}
.preview-topbar{
  height:40px;background:var(--s1);
  border-bottom:1px solid var(--rule);
  display:flex;align-items:center;padding:0 16px;gap:12px;
}
.preview-dots{display:flex;gap:5px}
.preview-dot{width:8px;height:8px;border-radius:50%;background:var(--rule)}
.preview-title{
  font-size:11px;font-weight:400;color:var(--t2);
  font-family:'DM Mono',monospace;
  flex:1;text-align:center;letter-spacing:0.04em;
}
.preview-body{
  display:grid;grid-template-columns:160px 1fr 280px;
  height:280px;
}
.preview-sidebar{
  background:var(--s0);border-right:1px solid var(--rule);
  padding:10px 8px;
}
.preview-sidebar-item{
  padding:5px 8px;border-radius:4px;
  font-size:10px;font-weight:300;color:var(--t2);
  margin-bottom:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
}
.preview-sidebar-item.active{background:var(--slate-pale);color:var(--slate);font-weight:500}
.preview-sidebar-label{
  font-family:'DM Mono',monospace;font-size:7px;
  letter-spacing:0.22em;text-transform:uppercase;
  color:var(--t3);padding:8px 8px 4px;
}
.preview-chat{padding:16px 20px;display:flex;flex-direction:column;gap:14px;overflow:hidden}
.preview-msg-ai{display:flex;gap:8px;align-items:flex-start}
.preview-avatar{
  width:22px;height:22px;border-radius:5px;
  background:var(--slate);flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
}
.preview-msg-text{font-size:11px;font-weight:300;color:var(--t1);line-height:1.6}
.preview-msg-text strong{font-weight:500;color:var(--t0)}
.preview-bubble{
  background:var(--slate);
  border-radius:8px 8px 8px 2px;
  padding:8px 12px;
  font-size:11px;color:rgba(244,246,250,0.85);line-height:1.6;
  max-width:80%;align-self:flex-end;
}
.preview-artifact{background:var(--s0);border-left:1px solid var(--rule);padding:12px 14px}
.preview-artifact-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.preview-artifact-title{font-size:11px;font-weight:500;color:var(--t0)}
.preview-artifact-sub{font-size:9px;color:var(--t3);margin-top:1px}
.preview-macro-row{display:flex;gap:10px;margin-bottom:10px}
.preview-macro{flex:1;text-align:center}
.preview-macro-val{
  font-family:'DM Mono',monospace;font-size:13px;
  font-weight:400;color:var(--amber);line-height:1;
}
.preview-macro-lbl{font-size:8px;color:var(--t3);margin-top:2px;letter-spacing:0.08em;text-transform:uppercase}
.preview-bar-row{margin-bottom:6px}
.preview-bar-label{display:flex;justify-content:space-between;font-size:8.5px;color:var(--t2);margin-bottom:3px}
.preview-bar-track{height:3px;background:var(--rule);border-radius:2px;overflow:hidden}
.preview-bar-fill{height:100%;border-radius:2px;background:var(--amber)}
.preview-bar-fill.slate{background:var(--slate)}
.preview-bar-fill.rule{background:var(--t3)}

/* ── STATS BAND ──────────────────────────────────────────── */
.stats-band{
  border-top:1px solid rgba(255,255,255,0.05);
  border-bottom:1px solid rgba(255,255,255,0.05);
  background:rgba(30,45,74,0.20);
  padding:52px 48px;
}
.stats-inner{
  max-width:900px;margin:0 auto;
  display:grid;grid-template-columns:repeat(4,1fr);gap:0;
}
.stat-block{text-align:center;padding:0 24px;border-right:1px solid rgba(255,255,255,0.06)}
.stat-block:last-child{border-right:none}
.stat-number{
  font-family:'DM Mono',monospace;
  font-size:38px;font-weight:400;
  color:#F4F6FA;letter-spacing:-0.03em;line-height:1;
}
.stat-number span{color:var(--amber);font-size:24px}
.stat-desc{font-size:12px;font-weight:300;color:rgba(255,255,255,0.35);margin-top:8px}

/* ── FEATURES ────────────────────────────────────────────── */
.section{padding:100px 48px;max-width:1100px;margin:0 auto}
.section-eyebrow{
  font-family:'DM Mono',monospace;
  font-size:9px;letter-spacing:0.28em;text-transform:uppercase;
  color:var(--amber);opacity:0.7;margin-bottom:16px;
}
.section-title{
  font-size:clamp(32px,3.5vw,48px);
  font-weight:600;letter-spacing:-0.035em;
  color:#F4F6FA;line-height:1.1;margin-bottom:16px;
}
.section-sub{
  font-size:15px;font-weight:300;
  color:rgba(255,255,255,0.35);line-height:1.7;max-width:520px;
}
.features-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:2px;margin-top:60px;
  border:1px solid rgba(255,255,255,0.06);
  border-radius:10px;overflow:hidden;
}
.feature-card{
  background:rgba(30,45,74,0.28);
  padding:32px 28px;
  border-right:1px solid rgba(255,255,255,0.06);
  transition:background 0.2s;
}
.feature-card:nth-child(3n){border-right:none}
.feature-card:hover{background:rgba(30,45,74,0.52)}
.feature-icon{
  width:36px;height:36px;border-radius:8px;
  background:rgba(200,120,32,0.09);
  border:1px solid rgba(200,120,32,0.18);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:20px;color:var(--amber);
}
.feature-title{font-size:15px;font-weight:500;color:#F4F6FA;margin-bottom:10px;letter-spacing:-0.02em}
.feature-text{font-size:13px;font-weight:300;color:rgba(255,255,255,0.36);line-height:1.7}

/* ── HOW IT WORKS ────────────────────────────────────────── */
.how-section{
  padding:100px 48px;
  border-top:1px solid rgba(255,255,255,0.05);
}
.how-inner{max-width:1100px;margin:0 auto}
.steps{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:1px;margin-top:60px;position:relative;
}
.steps::before{
  content:'';
  position:absolute;top:26px;left:calc(12.5% + 20px);right:calc(12.5% + 20px);
  height:1px;
  background:linear-gradient(to right,rgba(200,120,32,0.3),rgba(200,120,32,0.08));
}
.step{padding:0 20px;text-align:center}
.step-num{
  width:52px;height:52px;border-radius:50%;
  background:var(--slate-deep);
  border:1px solid rgba(200,120,32,0.28);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 20px;
  font-family:'DM Mono',monospace;font-size:13px;
  color:var(--amber);position:relative;z-index:1;
}
.step-title{font-size:14px;font-weight:500;color:#F4F6FA;margin-bottom:8px;letter-spacing:-0.02em}
.step-text{font-size:12.5px;font-weight:300;color:rgba(255,255,255,0.34);line-height:1.7}

/* ── TESTIMONIALS ────────────────────────────────────────── */
.testimonials{padding:100px 48px;max-width:1100px;margin:0 auto}
.testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:60px}
.testimonial{
  background:rgba(30,45,74,0.22);
  border:1px solid rgba(255,255,255,0.06);
  border-radius:10px;padding:28px;
  transition:border-color 0.2s;
}
.testimonial:hover{border-color:rgba(200,120,32,0.18)}
.testimonial-stars{display:flex;gap:3px;margin-bottom:16px}
.star{color:var(--amber);font-size:12px}
.testimonial-text{
  font-size:13.5px;font-weight:300;
  color:rgba(244,246,250,0.52);line-height:1.75;margin-bottom:20px;
}
.testimonial-author{display:flex;align-items:center;gap:10px}
.testimonial-avatar{
  width:32px;height:32px;border-radius:50%;
  background:var(--slate-mid);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:500;color:rgba(255,255,255,0.7);
}
.testimonial-name{font-size:12px;font-weight:500;color:rgba(255,255,255,0.6)}
.testimonial-role{font-size:11px;font-weight:300;color:rgba(255,255,255,0.28);margin-top:1px}

/* ── CTA ─────────────────────────────────────────────────── */
.cta-section{padding:100px 48px 120px;text-align:center;position:relative;overflow:hidden}
.cta-glow{
  position:absolute;bottom:-200px;left:50%;transform:translateX(-50%);
  width:900px;height:600px;
  background:radial-gradient(circle,rgba(200,120,32,0.09) 0%,transparent 60%);
  pointer-events:none;
}
.cta-inner{position:relative;z-index:1;max-width:560px;margin:0 auto}
.cta-title{font-size:clamp(36px,4vw,54px);font-weight:600;letter-spacing:-0.04em;color:#F4F6FA;line-height:1.1;margin-bottom:16px}
.cta-sub{font-size:15px;font-weight:300;color:rgba(255,255,255,0.35);line-height:1.7;margin-bottom:40px}
.cta-actions{display:flex;align-items:center;justify-content:center;gap:12px}
.cta-note{
  font-size:11px;font-weight:300;color:rgba(255,255,255,0.22);
  margin-top:16px;font-family:'DM Mono',monospace;letter-spacing:0.04em;
}

/* ── FOOTER ──────────────────────────────────────────────── */
footer{
  border-top:1px solid rgba(255,255,255,0.06);
  padding:36px 48px;
  display:flex;align-items:center;justify-content:space-between;
}
.footer-logo{display:flex;align-items:center;gap:10px}
.footer-wordmark{font-size:16px;font-weight:600;letter-spacing:-0.03em;color:rgba(255,255,255,0.38);line-height:1}
.footer-wordmark .veo{font-family:'Instrument Serif',serif;font-style:italic;font-weight:400;color:rgba(200,210,232,0.35);letter-spacing:0}
.footer-links{display:flex;gap:24px}
.footer-link{font-size:12px;font-weight:300;color:rgba(255,255,255,0.24);text-decoration:none;transition:color 0.12s}
.footer-link:hover{color:rgba(255,255,255,0.52)}
.footer-copy{font-size:11px;font-weight:300;color:rgba(255,255,255,0.18);font-family:'DM Mono',monospace}

/* ── ANIMATIONS ──────────────────────────────────────────── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(24px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:0.10s}
.reveal-delay-2{transition-delay:0.20s}
.reveal-delay-3{transition-delay:0.30s}
</style>
</head>
<body>

<!-- content.js must load before this script -->
<script is:inline src="/preveo_content.js"></script>

<script>
// ── RENDERER UTILITIES ────────────────────────────────────────────────────

// Resolves a color token name to a CSS value using PREVEO_COLORS map
function resolveColor(token) {
  return PREVEO_COLORS[token] || token;
}

// Renders a text spec (string OR array of segments) into an HTML string.
// Each segment: plain string, or { t: "text", c: "colorToken" }
function renderText(spec) {
  if (!spec) return '';
  if (typeof spec === 'string') return spec;
  return spec.map(seg => {
    if (typeof seg === 'string') return seg.replace(/\n/g, '<br>');
    const color = resolveColor(seg.c);
    const text = (seg.t || '').replace(/\n/g, '<br>');
    return `<span style="color:${color}">${text}</span>`;
  }).join('');
}

// Renders star icons
function renderStars(n) {
  return Array.from({length: n}, () => '<span class="star">★</span>').join('');
}

// Sun mark SVG — spec-compliant: 2/3 disc above horizon, near-white on dark
function sunSVG(size = 28) {
  const r = size * 0.45;
  const cx = size / 2;
  const hy = size * 0.55; // horizon y
  const cy = hy - r * 0.25; // disc centre: 1/4r below horizon → 2/3 above
  return `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}" fill="none" xmlns="http://www.w3.org/2000/svg">
    <defs><clipPath id="sc"><rect x="0" y="0" width="${size}" height="${hy}"/></clipPath></defs>
    <circle cx="${cx}" cy="${cy}" r="${r}" fill="#F4F6FA" clip-path="url(#sc)"/>
    <line x1="0" y1="${hy}" x2="${size}" y2="${hy}" stroke="rgba(200,120,32,0.35)" stroke-width="0.8"/>
  </svg>`;
}

// Sun SVG for nav (smaller, on dark background)
function navSunSVG() {
  return sunSVG(24);
}

// Feature icon SVGs keyed by icon name
const ICONS = {
  adaptive:  `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/></svg>`,
  nutrition: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>`,
  training:  `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  daily:     `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
  library:   `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  experts:   `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
};

// ── PAGE BUILDERS ─────────────────────────────────────────────────────────

function buildMeta() {
  document.title = PREVEO_CONTENT.meta.title;
  const desc = document.querySelector('meta[name="description"]');
  if (desc) desc.content = PREVEO_CONTENT.meta.description;
}

function buildNav() {
  const C = PREVEO_CONTENT.nav;
  document.getElementById('nav').innerHTML = `
    <a class="nav-logo" href="#">
      ${navSunSVG()}
      <div class="nav-wordmark">Pre<span class="veo">veo</span></div>
    </a>
    <div class="nav-links">
      ${C.links.map(l => `<a class="nav-link" href="${l.href}">${l.label}</a>`).join('')}
    </div>
    <div class="nav-right">
      <a class="nav-signin" href="/login">${C.signinLabel}</a>
      <a class="nav-cta" href="${C.ctaHref}">${C.ctaLabel}</a>
    </div>`;
}

function buildHero() {
  const C = PREVEO_CONTENT.hero;
  const proof = C.proof;
  document.getElementById('hero').innerHTML = `
    <div class="glow-amber"></div>
    <div class="glow-slate"></div>
    <div class="hero-horizon"></div>
    <div class="hero-inner">
      <div class="hero-eyebrow">${C.eyebrow}</div>
      <h1 class="hero-headline">${renderText(C.headline)}</h1>
      <p class="hero-sub">${C.sub}</p>
      <div class="hero-actions">
        <a class="btn-primary" href="${C.primaryBtn.href}">${C.primaryBtn.label}</a>
        <a class="btn-ghost" href="${C.secondaryBtn.href}">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          ${C.secondaryBtn.label}
        </a>
      </div>
      <div class="hero-proof">
        <div class="proof-avatars">
          ${proof.avatars.map(a => `<div class="proof-avatar">${a}</div>`).join('')}
        </div>
        <div class="proof-text">${renderText(proof.text)}</div>
      </div>
    </div>`;
}

function buildPreview() {
  const C = PREVEO_CONTENT.preview;
  const msgs = C.messages.map(m => {
    if (m.role === 'ai') return `
      <div class="preview-msg-ai">
        <div class="preview-avatar">${sunSVG(18)}</div>
        <div class="preview-msg-text">${m.html}</div>
      </div>`;
    return `<div class="preview-bubble">${m.text}</div>`;
  }).join('');

  const bars = C.artifact.bars.map(b => `
    <div class="preview-bar-row">
      <div class="preview-bar-label"><span>${b.label}</span><span>${b.value}</span></div>
      <div class="preview-bar-track"><div class="preview-bar-fill ${b.color}" style="width:${b.pct}%"></div></div>
    </div>`).join('');

  const macros = C.artifact.macros.map(m => `
    <div class="preview-macro">
      <div class="preview-macro-val">${m.value}</div>
      <div class="preview-macro-lbl">${m.label}</div>
    </div>`).join('');

  document.getElementById('preview').innerHTML = `
    <div class="preview-frame">
      <div class="preview-topbar">
        <div class="preview-dots">
          <div class="preview-dot"></div><div class="preview-dot"></div><div class="preview-dot"></div>
        </div>
        <div class="preview-title">${C.topbarTitle}</div>
      </div>
      <div class="preview-body">
        <div class="preview-sidebar">
          <div class="preview-sidebar-label">Recent</div>
          ${C.sidebar.map(s => `<div class="preview-sidebar-item${s.active ? ' active' : ''}">${s.label}</div>`).join('')}
        </div>
        <div class="preview-chat">${msgs}</div>
        <div class="preview-artifact">
          <div class="preview-artifact-header">
            <div>
              <div class="preview-artifact-title">${C.artifact.title}</div>
              <div class="preview-artifact-sub">${C.artifact.subtitle}</div>
            </div>
          </div>
          <div class="preview-macro-row">${macros}</div>
          ${bars}
        </div>
      </div>
    </div>`;
}

function buildStats() {
  document.getElementById('stats').innerHTML = `
    <div class="stats-inner">
      ${PREVEO_CONTENT.stats.map((s, i) => `
        <div class="stat-block reveal${i ? ' reveal-delay-' + i : ''}">
          <div class="stat-number">${s.number}<span>${s.unit}</span></div>
          <div class="stat-desc">${s.desc}</div>
        </div>`).join('')}
    </div>`;
}

function buildFeatures() {
  const C = PREVEO_CONTENT.features;
  document.getElementById('features').innerHTML = `
    <div class="reveal">
      <div class="section-eyebrow">${C.eyebrow}</div>
      <h2 class="section-title">${renderText(C.headline)}</h2>
      <p class="section-sub">${C.sub}</p>
    </div>
    <div class="features-grid">
      ${C.cards.map((card, i) => `
        <div class="feature-card reveal${i % 3 !== 0 ? ' reveal-delay-' + (i % 3) : ''}">
          <div class="feature-icon">${ICONS[card.icon] || ''}</div>
          <div class="feature-title">${card.title}</div>
          <div class="feature-text">${card.text}</div>
        </div>`).join('')}
    </div>`;
}

function buildHowItWorks() {
  const C = PREVEO_CONTENT.howItWorks;
  document.getElementById('how').innerHTML = `
    <div class="how-inner">
      <div class="reveal">
        <div class="section-eyebrow">${C.eyebrow}</div>
        <h2 class="section-title">${renderText(C.headline)}</h2>
      </div>
      <div class="steps">
        ${C.steps.map((s, i) => `
          <div class="step reveal${i ? ' reveal-delay-' + i : ''}">
            <div class="step-num">${s.num}</div>
            <div class="step-title">${s.title}</div>
            <div class="step-text">${s.text}</div>
          </div>`).join('')}
      </div>
    </div>`;
}

function buildTestimonials() {
  const C = PREVEO_CONTENT.testimonials;
  document.getElementById('testimonials').innerHTML = `
    <div class="reveal">
      <div class="section-eyebrow">${C.eyebrow}</div>
      <h2 class="section-title">${renderText(C.headline)}</h2>
    </div>
    <div class="testimonials-grid">
      ${C.items.map((t, i) => `
        <div class="testimonial reveal${i ? ' reveal-delay-' + i : ''}">
          <div class="testimonial-stars">${renderStars(t.stars)}</div>
          <p class="testimonial-text">"${t.quote}"</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">${t.initials}</div>
            <div>
              <div class="testimonial-name">${t.name}</div>
              <div class="testimonial-role">${t.role}</div>
            </div>
          </div>
        </div>`).join('')}
    </div>`;
}

function buildCTA() {
  const C = PREVEO_CONTENT.cta;
  document.getElementById('cta').innerHTML = `
    <div class="cta-glow"></div>
    <div class="cta-inner reveal">
      <h2 class="cta-title">${renderText(C.headline)}</h2>
      <p class="cta-sub">${C.sub}</p>
      <div class="cta-actions">
        <a class="btn-primary" href="${C.primaryBtn.href}">${C.primaryBtn.label}</a>
        <a class="btn-ghost" href="${C.ghostBtn.href}">${C.ghostBtn.label}</a>
      </div>
      <div class="cta-note">${C.note}</div>
    </div>`;
}

function buildFooter() {
  const C = PREVEO_CONTENT.footer;
  document.getElementById('footer').innerHTML = `
    <div class="footer-logo">
      ${sunSVG(20)}
      <div class="footer-wordmark">Pre<span class="veo">veo</span></div>
    </div>
    <div class="footer-links">
      ${C.links.map(l => `<a class="footer-link" href="${l.href}">${l.label}</a>`).join('')}
    </div>
    <div class="footer-copy">${C.copy}</div>`;
}

// ── BOOT ──────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  buildMeta();
  buildNav();
  buildHero();
  buildPreview();
  buildStats();
  buildFeatures();
  buildHowItWorks();
  buildTestimonials();
  buildCTA();
  buildFooter();

  // Scroll reveal
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.10 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
});
</script>

<meta name="description" content="">

<!-- ── SHELL ── all content injected by JS ── -->
<nav id="nav"></nav>

<section class="hero" id="hero"></section>

<div class="preview-wrap" id="preview"></div>

<div class="stats-band" id="stats"></div>

<section class="section" id="features"></section>

<section class="how-section" id="how"></section>

<section class="testimonials" id="testimonials"></section>

<section class="cta-section" id="cta"></section>

<footer id="footer"></footer>

</body>
</html>


